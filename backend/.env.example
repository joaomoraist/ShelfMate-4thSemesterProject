PORT=3000
SESSION_SECRET=change_me
NODE_ENV=development

# Database (Supabase/Render Postgres)
# Para Pooler da Supabase em produção, use porta 6543 e sslmode=require
DATABASE_URL=postgresql://user:password@aws-1-us-east-2.pooler.supabase.com:6543/postgres?sslmode=require

# Email provider (Resend)
RESEND_API_KEY=your_resend_api_key

# Chatbot (Gemini)
GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-2.5-flash

# Chatbot (Groq - legado/opcional)
# GROQ_API_KEY=your_groq_api_key
# GROQ_MODEL=openai/gpt-oss-20b